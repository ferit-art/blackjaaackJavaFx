<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="1000.0" maxWidth="1200.0" minHeight="1000.0" minWidth="1200.0" prefHeight="1000.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.Controller">
   <children>
      <Button fx:id="setButton" layoutX="551.0" layoutY="600.0" mnemonicParsing="false" onAction="#setBet" prefHeight="42.0" prefWidth="97.0" text="Set the bet">
         <font>
            <Font size="15.0" />
         </font></Button>
      <Label fx:id="betLabel" alignment="CENTER" contentDisplay="CENTER" layoutX="353.0" layoutY="378.0" prefHeight="152.0" prefWidth="494.0" styleClass="application.css" textAlignment="CENTER" wrapText="true">
         <font>
            <Font name="Hack Bold" size="13.0" />
         </font>
      </Label>
      <TextField fx:id="betInput" layoutX="551.0" layoutY="553.0" onAction="#setBet" prefHeight="27.0" prefWidth="97.0" />
      <Button fx:id="nextButton" layoutX="551.0" layoutY="601.0" mnemonicParsing="false" onAction="#toScene3" prefHeight="42.0" prefWidth="97.0" text="Continue" visible="false">
         <font>
            <Font size="17.0" />
         </font></Button>
      <Button fx:id="backButton" layoutX="14.0" layoutY="14.0" mnemonicParsing="false" onAction="#goBack" text="&lt;">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
